# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Test / coverage tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editor / OS noise
.vscode/
.idea/
*.swp
*~
.DS_Store

# Local design-blueprint sources (the in-repo architecture doc is architecture.md)
init.md
init.en.md

# eval/: publish only the metric lane that bench/ reuses (metrics.py +
# gen_samples.py); keep the separate de-optimization study private (run_eval,
# resilience, worklane, compare_obfuscators, report.tex, out/, samples/).
eval/*
!eval/__init__.py
!eval/metrics.py
!eval/gen_samples.py
!eval/README.md

# Local environment files / secrets
.env

# Benchmark: live config (holds the API key) and the PRIVATE held-out test split.
# Only the public `dev` split and the generator are committed; the held-out seed
# (BENCH_HELDOUT_SEED) and anything minted from it must never be committed.
bench/config.json
bench/.heldout_seed
bench/data/test/

# LaTeX build artifacts (e.g. paper/, when compiling the tool paper)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.synctex.gz
*.toc

# Note: tests/golden/ is intentionally tracked — those are test fixtures.
