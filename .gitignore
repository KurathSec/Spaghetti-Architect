# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Test / coverage tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editor / OS noise
.vscode/
.idea/
*.swp
*~
.DS_Store

# Local design-blueprint sources (the in-repo architecture doc is architecture.md)
init.md
init.en.md

# eval/: publish only the metric lane that bench/ reuses (metrics.py +
# gen_samples.py); keep the separate de-optimization study private (run_eval,
# resilience, worklane, compare_obfuscators, report.tex, out/, samples/).
eval/*
!eval/__init__.py
!eval/metrics.py
!eval/gen_samples.py
!eval/README.md

# Local environment files / secrets
.env

# Benchmark: live config (holds the API key) and the PRIVATE held-out test split.
# Only the public `dev` split and the generator are committed; the held-out seed
# (BENCH_HELDOUT_SEED) and anything minted from it must never be committed.
bench/config.json
bench/.heldout_seed
bench/data/test/
# ...including the transient finalize RESULT batches on that split: their
# `raw_outputs` embed the held-out literals verbatim (a refactor completion
# reproduces the input fixtures in full). The compacted test completions in
# bench/out/g3/ are a DELIBERATE auditability release (see bench/out/g3/README.md
# and the paper's limitations section); everything else minted from the seed
# stays out of version control.
bench/out/subagent/*__test.json

# Internal working notes (open problems, solutions, submission roadmap) — private.
bench/notes/

# The manuscripts live OUTSIDE this public code+dataset artifact and are kept LOCAL only:
#   paper/      — the DMLR resource paper (published separately: journal / arXiv)
#   archived/   — superseded + deferred drafts; `run_bench.py --report` regenerates the
#                 deferred benchmark-paper seed under archived/benchmark-paper/ on demand.
# The public repo is the engine + dataset; the paper gets its own DOI from the venue.
paper/
archived/

# LaTeX build artifacts (for any local paper build).
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv

# Note: tests/golden/ is intentionally tracked — those are test fixtures.

# live-run per-item checkpoints (transient; resumed from, then retired)
bench/out/subagent/*.partial.jsonl

# Annotation-ablation control-arm shards (BENCH_STRIP_ANNOTATIONS=1). Transient: the
# released arm is the compacted bench/out/ablation/*.jsonl.gz, which these compact into.
# Note run_bench._load_subagents also skips them at aggregate time, on two independent
# signals, so they can never pool into results.json.
bench/out/subagent/*__unannotated.json

# local Claude Code project file (not part of the artifact)
CLAUDE.md

# regenerable selftest mock fixtures (bench/run_bench.py --selftest); real results live in bench/out/{ladder,g3}/
bench/out/subagent/*mock*.json
# local review/audit notes — not part of the shipped artifact
/DMLR_REVIEW_AUDIT.md
/HANDOFF.md

# Vestigial double-blind anonymizer — DMLR is single-blind; kept local only.
scripts/anonymize_snapshot.py

# Ablation grade cache (rebuilt by bench/annotation_ablation.py; large, derived)
bench/out/.annotation_ablation_grades.json
