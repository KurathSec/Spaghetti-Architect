# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Test / coverage tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editor / OS noise
.vscode/
.idea/
*.swp
*~
.DS_Store

# Local design-blueprint sources (the in-repo architecture doc is architecture.md)
init.md
init.en.md

# eval/: publish only the metric lane that bench/ reuses (metrics.py +
# gen_samples.py); keep the separate de-optimization study private (run_eval,
# resilience, worklane, compare_obfuscators, report.tex, out/, samples/).
eval/*
!eval/__init__.py
!eval/metrics.py
!eval/gen_samples.py
!eval/README.md

# Local environment files / secrets
.env

# Benchmark: live config (holds the API key) and the PRIVATE held-out test split.
# Only the public `dev` split and the generator are committed; the held-out seed
# (BENCH_HELDOUT_SEED) and anything minted from it must never be committed.
bench/config.json
bench/.heldout_seed
bench/data/test/

# Internal working notes (open problems, solutions, submission roadmap) — private.
bench/notes/

# LaTeX build artifacts — both papers: paper/ (engine/metric-lane write-up) and
# bench/paper/ (the benchmark paper, emitted by `run_bench.py --report`). Submit the
# compiled PDF to the venue / arXiv; never commit it. The ACL style files
# (acl.sty, acl_natbib.bst) ARE meant to be committed if you vendor them for a
# repo-local build — they are build inputs, not artifacts.
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
paper/*.pdf
bench/paper/*.pdf
bench/paper/_build/
# regenerated draft from `--report` (the committed benchmark.tex is hand-maintained)
bench/paper/benchmark.generated.tex

# Note: tests/golden/ is intentionally tracked — those are test fixtures.
